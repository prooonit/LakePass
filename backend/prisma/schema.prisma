generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum MarinaRole {
  OWNER
  MANAGER
  STAFF
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum BoatType {
  YACHT
  PONTOON
  SPEED_BOAT
  FISHING_BOAT
  JET_SKI
  OTHER
}

enum BoatStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELLED
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String?
  googleId     String?      @unique
  avatarUrl    String?
  authProvider AuthProvider @default(EMAIL)

  memberships       MarinaMember[]
  marinaInvitations MarinaInvitation[]

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Marina {
  id          String @id @default(uuid())
  name        String
  slug        String @unique
  ownerUserId String

  memberships MarinaMember[]
  invitations MarinaInvitation[]

  boats Boat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarinaMember {
  id String @id @default(uuid())

  marinaId String
  userId   String

  role MarinaRole

  marina Marina @relation(fields: [marinaId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([marinaId, userId])
}

model MarinaInvitation {
  id String @id @default(uuid())

  marinaId         String
  email            String
  role             MarinaRole
  status           InvitationStatus @default(PENDING)
  invitedByUserId  String
  acceptedByUserId String?
  acceptedAt       DateTime?

  marina    Marina @relation(fields: [marinaId], references: [id])
  invitedBy User   @relation(fields: [invitedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([marinaId])
}

model Boat {
  id String @id @default(uuid())

  marinaId String

  name String

  boatCode String @unique

  description String?

  type BoatType

  capacity Int

  hourlyRate Decimal @db.Decimal(10, 2)

  status BoatStatus @default(ACTIVE)

  marina Marina @relation(fields: [marinaId], references: [id])

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marinaId])
  @@index([type])
}

model Booking {
  id String @id @default(uuid())

  boatId String
  userId String

  startTime DateTime
  endTime   DateTime

  totalPrice Decimal @db.Decimal(10, 2)

  status BookingStatus @default(PENDING)

  boat Boat @relation(fields: [boatId], references: [id])
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boatId])
  @@index([userId])
  @@index([startTime])
  @@index([endTime])
}
