generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  EMAIL
  GOOGLE
}



enum MarinaRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  avatarUrl    String?
  authProvider AuthProvider @default(EMAIL)

  memberships  MarinaMember[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Marina {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  ownerUserId String

  memberships MarinaMember[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MarinaMember {
  id        String @id @default(uuid())

  marinaId  String
  userId    String

  role      MarinaRole

  marina    Marina @relation(fields: [marinaId], references: [id])
  user      User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([marinaId, userId])
}
